// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/@prisma/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String          @id @default(cuid())
  email       String          @unique
  password    String
  displayName String
  avatarUrl   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  
  memberships ProjectMember[]
  activities  Activity[]
  comments    Comment[]
  reactions   CommentReaction[]
  tasks       Task[]          @relation("TaskAssignee")
  createdTasks Task[]         @relation("TaskCreator")
  uploadedImages TaskImage[]   @relation("ImageUploader")
  otpTokens OtpToken[]

  @@map("users")
}

model Project {
  id          String          @id @default(cuid())
  name        String
  description String?
  color       String          @default("#3b82f6")
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  members     ProjectMember[]
  tasks       Task[]
  activities  Activity[]
  labels      Label[]

  @@map("projects")
}

enum ProjectRole {
  ADMIN
  MEMBER
  VIEWER
}

model ProjectMember {
  id        String      @id @default(cuid())
  userId    String
  projectId String
  role      ProjectRole
  joinedAt  DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_members")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  projectId   String
  assigneeId  String?
  creatorId   String
  dueDate     DateTime?
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  creator     User         @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  
  comments    Comment[]
  activities  Activity[]
  images      TaskImage[]
  labels      TaskLabel[]
  dependencies TaskDependency[] @relation("BlockedTask")
  blocking     TaskDependency[] @relation("BlockingTask")

  @@map("tasks")
}

enum ActivityType {
  TASK_CREATED
  TASK_UPDATED
  STATUS_CHANGED
  TASK_COMPLETED
  COMMENT_ADDED
  MEMBER_ADDED
  MEMBER_REMOVED
}

model Activity {
  id        String       @id @default(cuid())
  type      ActivityType
  projectId String
  userId    String
  taskId    String?
  metadata  Json?
  createdAt DateTime     @default(now())

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  task      Task?        @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("activities")
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  taskId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions CommentReaction[]

  @@map("comments")
}

model TaskImage {
  id           String   @id @default(cuid())
  taskId       String
  originalName String
  storedName   String
  url          String
  size         Int
  mimeType     String
  uploaderId   String
  createdAt    DateTime @default(now())

  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploader     User     @relation("ImageUploader", fields: [uploaderId], references: [id], onDelete: Cascade)

  @@map("task_images")
}

enum OtpPurpose {
  PASSWORD_RESET
}

model OtpToken {
  id        String     @id @default(cuid())
  code      String
  userId    String
  purpose   OtpPurpose @default(PASSWORD_RESET)
  used      Boolean    @default(false)
  expiresAt DateTime
  createdAt DateTime   @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_tokens")
}

model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@map("comment_reactions")
}

model Label {
  id        String      @id @default(cuid())
  name      String
  color     String
  projectId String
  createdAt DateTime    @default(now())

  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     TaskLabel[]

  @@map("labels")
}

model TaskLabel {
  id        String   @id @default(cuid())
  taskId    String
  labelId   String

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label     Label    @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@map("task_labels")
}

model TaskDependency {
  id              String   @id @default(cuid())
  taskId          String
  blockedByTaskId String
  createdAt       DateTime @default(now())

  task            Task     @relation("BlockedTask", fields: [taskId], references: [id], onDelete: Cascade)
  blockedBy       Task     @relation("BlockingTask", fields: [blockedByTaskId], references: [id], onDelete: Cascade)

  @@unique([taskId, blockedByTaskId])
  @@map("task_dependencies")
}
